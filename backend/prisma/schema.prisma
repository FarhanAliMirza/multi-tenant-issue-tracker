// Prisma schema for Multi-Tenant Issue Tracker
// See backend/tech.md for details

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  users     User[]
  issues    Issue[]
}

model User {
  id           String   @id @default(uuid())
  name         String
  tenantId     String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  issues       Issue[]  @relation("CreatedIssues")
}

model Issue {
  id          String   @id @default(uuid())
  tenantId    String
  createdById String
  title       String
  description String?
  status      Status   @default(OPEN)
  priority    Priority @default(MEDIUM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdBy   User     @relation("CreatedIssues", fields: [createdById], references: [id])
}
